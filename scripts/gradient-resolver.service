[Unit]
Description=Gradient Linux Environment Intelligence Daemon
After=network.target

[Service]
Type=simple
User=gradient-svc
Group=gradient-svc
WorkingDirectory=/var/lib/gradient
ExecStart=/usr/local/bin/gradient-resolver run --workspace /var/lib/gradient --socket /run/gradient/resolver.sock
Restart=on-failure
RestartSec=10s
RuntimeDirectory=gradient
RuntimeDirectoryMode=0755
ReadWritePaths=/run/gradient /var/lib/gradient
UMask=0007

[Install]
WantedBy=multi-user.target
